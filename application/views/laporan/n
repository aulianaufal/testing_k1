     private function n_cetak($data, $table_type, $tanggal, $action = 'print')
    {
        if (empty($data)) {
            $view_data = [
                'title' => 'Laporan ' . ($table_type == 'barang_masuk' ? 'Barang Masuk' : 'Barang Keluar'),
                'table_type' => $table_type,
                'tanggal' => $tanggal,
                'no_data' => true,
                'action' => $action
            ];
            $this->load->view('laporan/cetak', $view_data);
            return;
        }


        $table_title = $table_type == 'barang_masuk' ? 'Barang Masuk' : 'Barang Keluar';


        if ($action == 'pdf') {
            include_once APPPATH.'third_party/fpdf/fpdf.php';
            $pdf = new FPDF('L', 'mm', 'A4');
            $pdf->AddPage();
            $pdf->SetMargins(10, 10, 10);


            // Header
            $pdf->SetFont('Times', 'B', 16);
            $pdf->Cell(0, 10, 'LAPORAN ' . strtoupper($table_title), 0, 1, 'C');
            $pdf->SetFont('Times', '', 12);
            $pdf->Cell(0, 7, 'Periode: ' . $tanggal, 0, 1, 'C');
            $pdf->Ln(10);


            // Table header
            $pdf->SetFont('Arial', 'B', 8);


            if ($table_type == 'barang_masuk') {
                $header = array('NO', 'TANGGAL', 'SUPPLIER', 'NOTA', 'JENIS BARANG', 'NAMA BARANG', 'SATUAN', 'JUMLAH', 'HARGA BELI', 'TOTAL', 'TUNAI', 'KREDIT', 'KETERANGAN');
                $widths = array(10, 25, 30, 25, 25, 30, 20, 15, 20, 20, 15, 15, 30);
            } else {
                $header = array('NO', 'TANGGAL', 'SUPPLIER', 'NOTA', 'JENIS BARANG', 'NAMA BARANG', 'SATUAN', 'JUMLAH', 'HARGA BELI', 'TOTAL', 'TUNAI', 'KREDIT', 'KETERANGAN');
                $widths = array(10, 25, 30, 25, 25, 30, 20, 15, 20, 20, 15, 15, 30);
            }


            // Print table header
            for ($i = 0; $i < count($header); $i++) {
                $pdf->Cell($widths[$i], 7, $header[$i], 1, 0, 'C');
            }
            $pdf->Ln();


            // Table content
            $pdf->SetFont('Arial', '', 8);
            $no = 1;


            foreach ($data as $row) {
                $pdf->Cell($widths[0], 6, $no++, 1, 0, 'C');


                if ($table_type == 'barang_masuk') {
                    $pdf->Cell($widths[1], 6, date('d/m/Y', strtotime($row['tanggal'])), 1, 0, 'C');
                    $pdf->Cell($widths[2], 6, $row['nama_supplier'], 1, 0, 'L');
                    $pdf->Cell($widths[3], 6, $row['nota'], 1, 0, 'C');
                    $pdf->Cell($widths[4], 6, $row['nama_jenis'], 1, 0, 'L');
                    $pdf->Cell($widths[5], 6, $row['nama_barang'], 1, 0, 'L');
                    $pdf->Cell($widths[6], 6, $row['nama_satuan'], 1, 0, 'C');
                    $pdf->Cell($widths[7], 6, $row['jumlah_masuk'], 1, 0, 'C');
                    $pdf->Cell($widths[8], 6, number_format($row['harga_setelah_potongan'], 0, ',', '.'), 1, 0, 'R');
                    $pdf->Cell($widths[9], 6, number_format($row['total'], 0, ',', '.'), 1, 0, 'R');
                    $pdf->Cell($widths[10], 6, $row['tunai'], 1, 0, 'C');
                    $pdf->Cell($widths[11], 6, $row['kredit'], 1, 0, 'C');
                    $pdf->Cell($widths[12], 6, $row['keterangan'], 1, 0, 'L');
                } else {
                    $pdf->Cell($widths[1], 6, date('d/m/Y', strtotime($row['tanggal_keluar'])), 1, 0, 'C');
                    $pdf->Cell($widths[2], 6, $row['nama_supplier'], 1, 0, 'L');
                    $pdf->Cell($widths[3], 6, $row['nota'], 1, 0, 'C');
                    $pdf->Cell($widths[4], 6, $row['nama_jenis'], 1, 0, 'L');
                    $pdf->Cell($widths[5], 6, $row['nama_barang'], 1, 0, 'L');
                    $pdf->Cell($widths[6], 6, $row['nama_satuan'], 1, 0, 'C');
                    $pdf->Cell($widths[7], 6, $row['jumlah_keluar'], 1, 0, 'C');
                    $pdf->Cell($widths[8], 6, number_format($row['harga_setelah_potongan'], 0, ',', '.'), 1, 0, 'R');
                    $pdf->Cell($widths[9], 6, number_format($row['total'], 0, ',', '.'), 1, 0, 'R');
                    $pdf->Cell($widths[10], 6, $row['tunai'], 1, 0, 'C');
                    $pdf->Cell($widths[11], 6, $row['kredit'], 1, 0, 'C');
                    $pdf->Cell($widths[12], 6, $row['keterangan'], 1, 0, 'L');
                }
                $pdf->Ln();
            }


            $filename = 'Laporan_' . $table_title . '_' . str_replace(' - ', '_sampai_', $tanggal);
            $filename = preg_replace('/[^A-Za-z0-9_\-]/', '_', $filename);
            $pdf->Output('D', $filename . '.pdf');
        } else {
            // Untuk opsi print, tampilkan HTML
            $view_data = [
                'title' => 'Laporan ' . $table_title,
                'table_type' => $table_type,
                'tanggal' => $tanggal,
                'data' => $data,
                'action' => $action
            ];
            $this->load->view('laporan/cetak', $view_data);
        }
    }