                                public function getBarangMasuk()
{
    $this->db->select('
        bm.*,
        b.nama_barang,
        sup.nama_supplier,
        sat.nama_satuan,
        j.nama_jenis
    ');
    $this->db->from('barang_masuk bm');
    $this->db->join('barang b', 'b.id_barang = bm.barang_id', 'left');
    $this->db->join('supplier sup', 'sup.id_supplier = bm.supplier_id', 'left');
    $this->db->join('satuan sat', 'sat.id_satuan = b.id_satuan', 'left');
    $this->db->join('jenis j', 'j.id_jenis = b.id_jenis', 'left');
    $this->db->order_by('bm.tanggal', 'DESC');
    
    return $this->db->get()->result_array();
}
