<script>
$(document).ready(function() {
    // When jenis is selected, load barang
    $('#jenis_id').change(function() {
        var jenis_id = $(this).val();
        if(jenis_id) {
            $('#barang_id').prop('disabled', false);
            $.ajax({
                url: '<?= base_url('barangmasuk/get_barang_by_jenis/') ?>' + jenis_id,
                type: 'GET',
                dataType: 'json',
                success: function(data) {
                    $('#barang_id').html('<option value="">Pilih Barang</option>');
                    $.each(data, function(key, value) {
                        $('#barang_id').append('<option value="'+ value.id_barang +'">'+ value.nama_barang +'</option>');
                    });
                    // Reset dependent fields
                    $('#stok').val('');
                    $('#harga_beli').val('');
                    $('#total').val('');
                },
                error: function(xhr, status, error) {
                    console.error('Error:', error);
                    $('#barang_id').html('<option value="">Pilih Barang</option>');
                }
            });
        } else {
            $('#barang_id').prop('disabled', true);
            $('#barang_id').html('<option value="">Pilih Barang</option>');
            // Reset dependent fields
            $('#stok').val('');
            $('#harga_beli').val('');
            $('#total').val('');
        }
    });

    // When barang is selected, load details
    $('#barang_id').change(function() {
        var barang_id = $(this).val();
        if(barang_id) {
            $.ajax({
                url: '<?= base_url('barangmasuk/get_barang_details/') ?>' + barang_id,
                type: 'GET',
                dataType: 'json',
                success: function(data) {
                    $('#stok').val(data.stok);
                    if ($('#harga_beli').val() === '') {
                        $('#harga_beli').val(data.harga_beli);
                    }
                    // Calculate total if jumlah_masuk has value
                    if ($('#jumlah_masuk').val() !== '') {
                        var harga = parseFloat($('#harga_beli').val()) || 0;
                        var jumlah = parseFloat($('#jumlah_masuk').val()) || 0;
                        $('#total').val(harga * jumlah);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error:', error);
                    $('#stok').val('');
                    $('#harga_beli').val('');
                    $('#total').val('');
                }
            });
        } else {
            $('#stok').val('');
            $('#harga_beli').val('');
            $('#total').val('');
        }
    });

    // Initialize datepicker
    $('.date').daterangepicker({
        singleDatePicker: true,
        showDropdowns: true,
        locale: {
            format: 'YYYY-MM-DD'
        },
        ranges: {}
    });

    // Calculate total when harga_beli or jumlah_masuk changes
    $('#harga_beli, #jumlah_masuk').on('input', function() {
        var harga = parseFloat($('#harga_beli').val()) || 0;
        var jumlah = parseFloat($('#jumlah_masuk').val()) || 0;
        $('#total').val(harga * jumlah);
    });
});
</script>

