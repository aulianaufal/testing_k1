                            $(column.header()).append('<div style="margin-top: 5px;"></div>');
                            return;
                        }
                        
                        // Create search input for each column
                        var input = $('<input type="text" class="form-control form-control-sm" placeholder="Cari ' + title + '" style="margin-top: 5px; font-size: 11px;">')
                            .appendTo($(column.header()))
                            .on('keyup change clear', function () {
                                if (column.search() !== this.value) {
                                    column.search(this.value).draw();
                                }
                            });
                    });
                },
                
                // Custom search functionality
                "dom": '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>' +
                       '<"row"<"col-sm-12"tr>>' +
                       '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
                
                // Search highlight
                "searchHighlight": true
            });
        } catch (e) {
            console.error('Error initializing DataTable:', e);
            // Fallback: coba inisialisasi sederhana
            $('#dataTable').DataTable({
                "destroy": true,
                "pageLength": 25,
                "searching": true // Enable search di fallback juga
            });
        }
    }, 100);
});

